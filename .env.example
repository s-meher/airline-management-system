# PostgreSQL connection (docker-compose matches host port 5432).
DATABASE_URL="postgres://postgres:postgres@localhost:5432/flightdesk"

# JWT signing secret — use a long random string in production (32+ characters).
AUTH_SECRET="replace-with-a-long-random-secret-for-development-only"

# Optional: bcrypt password applied to seeded demo users during `npm run db:seed`
# (default when unset: flightdesk)
# SEED_USER_PASSWORD="flightdesk"
