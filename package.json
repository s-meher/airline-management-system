{
  "name": "airline-management-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down -v",
    "db:migrate": "tsx scripts/db/migrate.ts",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:reset": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.2.4",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "16.2.4",
    "pg": "^8.16.3",
    "postcss": "8.5.12",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.2.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.19.39",
    "@types/pg": "^8.15.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "^16.6.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "tsx": "^4.20.5",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
